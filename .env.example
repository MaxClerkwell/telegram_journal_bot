TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
JOURNAL_REPO=git@github.com:youruser/your-journal-repo.git
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
GITHUB_TOKEN=
GOOGLE_API_KEY=
# For Anthropic: LLM_PROVIDER=anthropic, ANTHROPIC_API_KEY=
# For OpenAI: LLM_PROVIDER=openai, OPENAI_API_KEY=

# Git identity for commits
GIT_USER_NAME=Journal Bot
GIT_USER_EMAIL=journal@bot.local

# Path to the SSH private key used for cloning the journal repo (e.g. ~/.ssh/github)
SSH_PRIVATE_KEY_PATH=/path/to/your/ssh/private/key
